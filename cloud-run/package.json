{
  "name": "grass-volleyball-processor",
  "version": "1.0.0",
  "description": "Cloud Run video processing worker for Grass Volleyball",
  "main": "dist/worker.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/worker.js",
    "dev": "tsx --env-file=.env src/worker.ts",
    "test": "tsx --env-file=.env src/test_worker.ts",
    "process-local": "tsx --env-file=.env src/process_local.ts",
    "youtube-cleanup": "tsx --env-file=.env src/youtube_cleanup.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
