# Cloud Run Processor Environment Variables
# Copy this file to .env and fill in values

# Firebase
# Generate a service account key from GCP Console → IAM → Service Accounts
# Base64-encode it:  base64 -i service-account.json
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# YouTube OAuth (same as root .env)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Port (Cloud Run sets this automatically)
PORT=8080

# For test_worker.ts only
WORKER_URL=http://localhost:8080


